{
  "name": "issue-management",
  "private": true,
  "version": "0.1.0",
  "description": "Codex companion for issue and snag management",
  "author": "Anything IT",
  "type": "module",
  "main": "electron/main.mjs",
  "bin": {
    "issue-manager": "./bin/issue-manager.js"
  },
  "scripts": {
    "api": "node server/api.js",
    "dev": "vite",
    "dev:app": "vite --host 0.0.0.0",
    "desktop": "npm run build && electron .",
    "desktop:dev": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "issue": "node bin/issue-manager.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "net.anythingit.codex-companion",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "npmRebuild": false,
    "productName": "Codex Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "issues/**/*",
      "package.json"
    ],
    "win": {
      "executableName": "Codex Companion",
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "oneClick": false,
      "perMachine": false,
      "shortcutName": "Codex Companion",
      "uninstallDisplayName": "Codex Companion"
    }
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
